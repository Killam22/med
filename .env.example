# ── MedSmart Backend — variables d'environnement ──────────────────────────────
# Copier ce fichier en .env et remplir les valeurs réelles.
# Ne jamais committer .env dans git.

# Django
SECRET_KEY=replace-with-a-long-random-secret-key
DEBUG=True
ALLOWED_HOSTS=*

# Base de données PostgreSQL
DB_NAME=medical_db
DB_USER=postgres
DB_PASSWORD=your-db-password
DB_HOST=localhost
DB_PORT=5432

# Email (Gmail SMTP — utiliser un App Password généré
# depuis les paramètres de sécurité Google, pas le vrai mot de passe)
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password

# CORS
# En dev : CORS_ALLOW_ALL=True
# En prod : CORS_ALLOW_ALL=False et renseigner CORS_ALLOWED_ORIGINS
CORS_ALLOW_ALL=True
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://medsmart.example.com

# IA Diagnostic (Google Gemini)
# Créer une clé sur https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash
